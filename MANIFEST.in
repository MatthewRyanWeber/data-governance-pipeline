include README.md
include LICENSE
include CHANGELOG.md
include CLAUDE.md
include pyproject.toml

recursive-include pipeline *.py
recursive-include config *.json

prune tests
prune docs
prune .github
prune __pycache__
global-exclude *.pyc *.pyo *.egg-info
global-exclude .DS_Store Thumbs.db
global-exclude *.db *.sqlite *.sqlite3
global-exclude .env .env.*
